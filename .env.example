NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxx
NEXT_PUBLIC_CONVEX_URL=https://example-123.convex.cloud
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://your-app.clerk.accounts.dev
# From Clerk → Webhooks → your endpoint → Signing secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxx

# Convex dashboard (set per deployment — dev and prod use different values):
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN "https://your-app.clerk.accounts.dev"
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN "https://clerk.logasiko.com" --prod
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev
# CLERK_SECRET_KEY=sk_test_...  (Convex dashboard — for invite actions)

# Optional: public site URL for invite redirects
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# CLERK_INVITE_REDIRECT_URL=http://localhost:3000/dashboardStaff
